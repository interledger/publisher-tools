{
  "name": "publisher-tools-api",
  "version": "1.0.0",
  "scripts": {
    "predev": "node -e \"require('fs').copyFileSync('../.dev.vars', '.dev.vars');\"",
    "dev": "wrangler dev --persist-to ../.wrangler",
    "build": "node build.ts",
    "preview": "wrangler dev",
    "prepare": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "wrangler d1 migrations apply publisher-tools --local --persist-to  ../.wrangler",
    "migrate:prod": "wrangler d1 migrations apply publisher-tools --remote",
    "deploy": "wrangler deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@interledger/open-payments": "^7.4.0",
    "@noble/ed25519": "^3.1.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@shared/config-storage-service": "workspace:^",
    "@shared/default-data": "workspace:^",
    "@shared/probabilistic-revenue-share": "workspace:^",
    "@shared/utils": "workspace:^",
    "hono": "^4.12.27",
    "http-message-signatures": "^1.0.6",
    "httpbis-digest-headers": "^1.0.0",
    "zod": "^4.4.3"
  },
  "types": "./src/types.ts",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@cloudflare/workers-types": "^4.20260629.1",
    "@shared/defines": "workspace:^",
    "@shared/types": "workspace:^",
    "esbuild": "0.28.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
