{
  "name": "publisher-tools-cdn",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run -F publisher-tools-cdn --parallel \"/^dev:.*/\"",
    "dev:build": "pnpm build:clean && node --watch --watch-path=./src --watch-path=build.js --watch-path=../components build.js",
    "dev:server": "wrangler dev",
    "build": "node build.js",
    "build:clean": "del-cli 'dist/**' '!dist/.gitkeep'",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/open-sans": "^5.3.0",
    "@fontsource-variable/roboto": "^5.3.0",
    "@fontsource/cookie": "^5.3.0",
    "@fontsource/titillium-web": "^5.3.0",
    "@shared/defines": "workspace:^",
    "@shared/types": "workspace:^",
    "@shared/utils": "workspace:^",
    "@tools/components": "workspace:*",
    "directory-tree": "^3.6.0",
    "esbuild": "0.28.1",
    "esbuild-plugin-copy": "^2.1.1",
    "publisher-tools-api": "workspace:^",
    "wrangler": "^4.105.0"
  }
}
